{
  "name": "worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "corepack pnpm --filter @tracker/shared build && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "once": "corepack pnpm --filter @tracker/shared build && tsx src/index.ts --once"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@tracker/shared": "workspace:*",
    "fast-xml-parser": "^5.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
